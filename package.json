{
  "name": "product-agent-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fast": "vitest run src/test/contracts src/test/smoke",
    "test:fixture-contracts": "node scripts/check-fixture-contracts.mjs",
    "test:contracts": "vitest run src/test/contracts",
    "test:smoke": "vitest run src/test/smoke"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^27.3.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.0.15"
  }
}
